{
  "name": "tibetan-ansi-to-unicode",
  "version": "1.8.0",
  "description": "Convert between ANSI encoded Tibetan text and Unicode, with font-aware conversion from Word (.docx) and RTF",
  "type": "module",
  "main": "index.js",
  "module": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "files": [
    "index.js",
    "src/**/*.js",
    "THIRD_PARTY_NOTICES.md",
    "LICENSES"
  ],
  "scripts": {
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "keywords": [
    "tibetan",
    "unicode",
    "ansi",
    "converter",
    "text",
    "docx",
    "rtf",
    "sanskrit"
  ],
  "author": "Jeremy FRERE",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jerefrer/tibetan-ansi-to-unicode.git"
  },
  "bugs": {
    "url": "https://github.com/jerefrer/tibetan-ansi-to-unicode/issues"
  },
  "homepage": "https://github.com/jerefrer/tibetan-ansi-to-unicode#readme"
}
